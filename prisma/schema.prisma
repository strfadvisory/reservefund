// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model Post {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  friend      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  companyType    String
  companyName    String?
  firstName      String?
  lastName       String?
  designation    String?
  phone          String?
  passwordHash   String?
  verified       Boolean   @default(false)
  otpHash        String?
  otpExpiresAt   DateTime?
  logoFileId     String?
  website        String?
  linkedin       String?
  zipCode        String?
  state          String?
  city           String?
  address1       String?
  address2       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
}

model Association {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @db.ObjectId
  associationName    String
  managerFirstName   String?
  managerLastName    String?
  managerEmail       String?
  associationEmail   String?
  cellPhone          String?
  telephone          String?
  zipCode            String?
  state              String?
  city               String?
  address1           String?
  address2           String?
  logoFileId         String?
  published          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Invite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  invitedBy  String   @db.ObjectId
  associationId String? @db.ObjectId
  firstName  String
  lastName   String
  email      String
  token      String?  @unique
  status     String   @default("pending")
  linkedUserId String? @db.ObjectId
  designation String?
  permissions Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ReserveStudy {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  associationId String   @db.ObjectId
  fileName      String
  fileId        String
  size          Int
  contentType   String?
  createdAt     DateTime @default(now())
}

model Study {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                  String   @db.ObjectId
  associationId           String?  @db.ObjectId
  modelName               String
  housingUnits            String?
  beginningReserveFunds   String?
  sirsReserveFunds        String?
  inflationRate           String?
  averageMonthlyFee       String?
  beginningFiscalYear     String?
  yearsCovered            String?
  rateOfReturn            String?
  items                   Json
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SuperAdmin {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  username     String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  token        String     @unique
  adminId      String     @db.ObjectId
  admin        SuperAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
}
